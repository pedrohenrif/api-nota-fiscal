ENV=development
POLL_INTERVAL_MINUTES=6
EXTRACTION_SCHEDULER_ENABLED=false
EXTRACTION_RUN_ON_STARTUP=false
USE_MOCK_ORACLE=true

# Extracao: false = disparo manual pelo site (recomendado em homolog inicial)
#             true  = ciclo automatico a cada POLL_INTERVAL_MINUTES (4 estabelecimentos)

ORACLE_DSN=oracle+cx_oracle://user:password@host:1521/?service_name=TASY
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE_RAW_NF=nf.raw
RABBITMQ_QUEUE_DEAD=nf.dead
POSTGRES_URL=postgresql://tasy:tasy@localhost:5432/tasy_db

# Nota: ao usar Docker Compose, db/rabbitmq/extractor usam hosts internos
# (db, rabbitmq, extractor-service). Os valores localhost acima servem
# apenas se rodar os servicos Python direto na maquina, sem Docker.

# PR - ambiente ativo: homolog (altere para production quando for para producao)
PR_ENV=homolog

# Homologacao
PR_BASE_URL_HOMOLOG=http://prsistemas.ddns.net:6728/PREstAPI
PR_HOMOLOG_TOKEN=42F6A807-AB4E-4C86-AF66-BDB5BDA045F0

# Producao (usado apenas quando PR_ENV=production)
PR_BASE_URL_PRODUCTION=http://131.72.96.43:4780/PREstAPI
PR_CASTELO_TOKEN=9EEAD5CE-639D-43BF-83AB-48116F51A41B
PR_HRAS_TOKEN=8910D4E2-731E-45CF-BE43-F9D47209487E
PR_HRT_TOKEN=4936C942-ACAF-478A-9ADB-86BE99FE4576
PR_PONTA_PORA_TOKEN=AD594FE2-5A81-4444-A8F3-D3BD8BBD6529

# Web API / painel
JWT_SECRET=dev-secret-change-me
JWT_EXPIRE_MINUTES=480
EXTRACTOR_URL=http://localhost:8001
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
CORS_ORIGINS=http://localhost:5173
